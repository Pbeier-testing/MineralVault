@page "/"
@using MineralCollection.Domain
@inject HttpClient Http

<PageTitle>MineralVault - Collection</PageTitle>

<h1>My Mineral Collection</h1>

@if (minerals == null)
{
    <p><em>Loading your minerals...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Location</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in minerals)
            {
                <tr>
                    <td>@m.Name</td>
                    <td>@m.Fundort</td>
                    <td>@m.Beschreibung</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Mineral[]? minerals;

    protected override async Task OnInitializedAsync()
    {
        // API-Aufruf, um die Mineralien zu laden.
        // Fehlerbehandlung hinzugefügt, um mögliche Probleme beim Laden der Daten zu erkennen und zu protokollieren.
        try
        {
            minerals = await Http.GetFromJsonAsync<Mineral[]>("api/minerals");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}