@page "/"
@using MineralCollection.Domain
@using MineralCollection.Frontend.ViewModels
@implements IDisposable
@inject HomeViewModel VM

@if (ActiveTab == "explorer")
{
    @* Kartenmodus *@
    <div class="row g-0 h-100" style="height: 100vh;" data-testid="map-view">
        @* Linke Seite: Die Karte *@
        <div class="col-lg-8 col-md-7 position-relative bg-light border-end h-100">
            <div id="map" style="height: 100%; width: 100%;" data-testid="leaflet-map">
                <div class="d-flex h-100 align-items-center justify-content-center">
                    <p class="text-muted">Karte wird geladen...</p>
                </div>
            </div>
        </div>

        @* Rechte Seite: Galerie & Suche *@
        <div class="col-lg-4 col-md-5 d-flex flex-column bg-white h-100 shadow-sm">
            @* Such- und Filterbereich *@
            <div class="p-3 border-bottom bg-light">
                <div class="input-group mb-2 shadow-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Mineral suchen..."
                           data-testid="map-search-input"
                           @bind="VM.SearchTerm" @bind:event="oninput" />
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <small class="text-secondary fw-bold" data-testid="mineral-count">@VM.FilteredMinerals.Count() Funde</small>
                    <select class="form-select form-select-sm w-auto" data-testid="map-sort-select" @bind="VM.SortBy">
                        <option value="Name">Sortieren: Name</option>
                        <option value="Region">Sortieren: Region</option>
                        <option value="Nummer">Sortieren: Nr.</option>
                    </select>
                </div>
            </div>

            @* Die Mineralienliste *@
            <div class="overflow-auto flex-grow-1 p-3 bg-white" style="overflow-y: auto !important;" data-testid="mineral-card-list">
                @if (VM.Minerals == null)
                {
                    <div class="text-center p-5" data-testid="mineral-loading">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Lade Sammlung...</p>
                    </div>
                }
                else
                {
                    @foreach (var m in VM.FilteredMinerals)
                    {
                        <div class="card mb-3 mineral-card border-0 shadow-sm" @onclick="() => VM.HandleSelectAsync(m.Id)"
                             data-testid="mineral-card"
                             data-mineral-id="@m.Id"
                             style="cursor: pointer;">
                            <div class="row g-0">
                                <div class="col-4">
                                    @{
                                        var firstImg = m.Images?.FirstOrDefault()?.FileName;
                                        if (!string.IsNullOrEmpty(firstImg))
                                        {
                                            <img src="images/@firstImg" class="img-fluid rounded-start h-100"
                                                 style="object-fit: cover; min-height: 110px;" alt="@m.Name">
                                        }
                                        else
                                        {
                                            <div class="bg-light h-100 d-flex align-items-center justify-content-center rounded-start text-muted">
                                                <i class="bi bi-camera fs-4"></i>
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="col-8 p-2">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <h6 class="card-title fw-bold text-dark mb-0">@m.Name</h6>
                                        <span class="badge bg-light text-dark border" style="font-size: 0.6rem;">#@m.Nummer</span>
                                    </div>
                                    <div class="text-muted small mb-1" style="font-size: 0.8rem;">
                                        <i class="bi bi-geo-alt-fill text-danger"></i> @m.Region
                                    </div>
                                    @if (!string.IsNullOrEmpty(m.Begleitmineral))
                                    {
                                        <div class="mb-1">
                                            <span class="badge bg-soft-success text-success border border-success"
                                                  style="font-size: 0.7rem;">+ @m.Begleitmineral</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(m.Bemerkungen))
                                    {
                                        <p class="card-text text-muted small text-truncate-2 mb-0"
                                           style="font-size: 0.7rem; line-height: 1.2;">
                                            @m.Bemerkungen
                                        </p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}
else if (ActiveTab == "admin")
{
    @* Tabellenübersicht *@
    <div class="container-fluid p-4 h-100 d-flex flex-column bg-light" style="height: 100vh; overflow: hidden;" data-testid="table-view">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>Sammlungs-Verwaltung</h2>
            <div class="d-flex gap-2">
                <div class="input-group" style="width: 300px;">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Tabelle filtern..." @bind="VM.SearchTerm"
                           data-testid="table-search-input"
                           @bind:event="oninput" />
                </div>
                <button class="btn btn-primary px-3" data-testid="add-mineral-button" @onclick="VM.CreateNewMineral"><i class="bi bi-plus-lg me-1"></i> Neu hinzufügen</button>
                <button class="btn btn-success px-3" data-testid="save-minerals-button" @onclick="VM.SaveChangesAsync" disabled="@VM.IsSaving">
                    @if (VM.IsSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Speichert...</span>
                    }
                    else
                    {
                        <i class="bi bi-cloud-arrow-up me-1"></i>
                        <span>Speichern</span>
                    }
                </button>
            </div>
        </div>

        <div class="card shadow-sm border-0 flex-grow-1 overflow-hidden">
            <div class="table-responsive h-100" style="overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 bg-white" data-testid="minerals-table">
                    <thead class="table-dark sticky-top">
                        <tr class="text-nowrap">
                            <th style="width: 60px;">Nr.</th>
                            <th style="width: 60px;">Bild</th>
                            <th>Hauptmineral</th>
                            <th>Begleitmineral</th>
                            <th>Fundort</th>
                            <th>Region</th>
                            <th>Land</th>
                            <th style="width: 80px;">Fundjahr</th>
                            <th style="width: 80px;">Erwerbjahr</th>
                            <th>Koordinaten (Lat/Lon)</th>
                            <th class="text-end">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (VM.Minerals != null)
                        {
                            @foreach (var m in VM.FilteredMinerals)
                            {
                                <tr class="@(m.Id == 0 ? "table-row-new" : "")" style="transition: background-color 0.5s ease;" data-testid="mineral-table-row" data-mineral-id="@m.Id">
                                    <td><input type="text" class="form-control form-control-sm border-0 bg-light" data-testid="mineral-number-input" @bind="m.Nummer" /></td>
                                    <td>
                                        <div class="position-relative shadow-sm rounded border" style="width: 50px; height: 50px; overflow: hidden; background: #f8f9fa;">
                                            @{
                                                var currentImg = m.Images?.FirstOrDefault()?.FileName;
                                                if (!string.IsNullOrEmpty(currentImg))
                                                {
                                                    <img src="images/@currentImg" @key="currentImg" class="w-100 h-100" style="object-fit: cover; cursor: pointer;" @onclick="() => VM.OpenImagePreview(currentImg)" />
                                                }
                                                else
                                                {
                                                    <img src="images/placeholder.jpg" class="w-100 h-100 opacity-50" style="object-fit: cover;" />
                                                }
                                            }
                                            <InputFile OnChange="@(e => VM.HandleImageUploadAsync(e.File, m))" data-testid="mineral-image-input" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer; z-index: 10;" />
                                        </div>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm fw-bold border-0 bg-light" data-testid="mineral-name-input" @bind="m.Name" /></td>
                                    <td><input type="text" class="form-control form-control-sm border-0" data-testid="mineral-companion-input" @bind="m.Begleitmineral" /></td>
                                    <td><input type="text" class="form-control form-control-sm border-0" data-testid="mineral-location-input" @bind="m.Fundort" /></td>
                                    <td><input type="text" class="form-control form-control-sm border-0" data-testid="mineral-region-input" @bind="m.Region" /></td>
                                    <td><input type="text" class="form-control form-control-sm border-0" data-testid="mineral-country-input" @bind="m.Land" /></td>
                                    <td><input type="number" class="form-control form-control-sm border-0" data-testid="mineral-discovery-year-input" @bind="m.Fundjahr" /></td>
                                    <td><input type="number" class="form-control form-control-sm border-0" data-testid="mineral-acquisition-year-input" @bind="m.Erwerbsjahr" /></td>
                                    <td>
                                        <div class="d-flex gap-1 align-items-center">
                                            <input type="number" step="any" class="form-control form-control-sm border-0 text-primary p-0" style="width: 65px;" data-testid="mineral-latitude-input" @bind="m.Breitengrad" />
                                            <span class="text-muted">|</span>
                                            <input type="number" step="any" class="form-control form-control-sm border-0 text-primary p-0" style="width: 65px;" data-testid="mineral-longitude-input" @bind="m.Laengengrad" />
                                            <button class="btn btn-sm btn-outline-primary border-0 p-1" data-testid="open-coordinate-picker-button" @onclick="() => VM.OpenCoordPickerAsync(m)">
                                                <i class="bi bi-map"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger border-0" data-testid="delete-mineral-button" @onclick="() => VM.DeleteMineralAsync(m)"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@*Koordinaten-Picker Modal*@
@if (VM.ShowCoordPicker)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); z-index: 1050;" tabindex="-1" data-testid="coordinate-picker-modal">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-geo-alt-fill me-2"></i>
                        Fundort wählen: @VM.ActiveMineral?.Name
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-testid="coordinate-picker-close-button" @onclick="VM.CloseCoordPicker"></button>
                </div>
                <div class="modal-body p-0 position-relative">
                    <div id="pickerMap" style="height: 450px; width: 100%;" data-testid="coordinate-picker-map"></div>
                    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-3 bg-white px-3 py-1 rounded-pill shadow-sm small fw-bold" style="z-index: 1000; pointer-events: none;">
                        Klicke auf die Karte, um den Punkt zu setzen
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <div class="me-auto">
                        <span class="badge bg-white text-dark border p-2" data-testid="coordinate-picker-value">
                            Lat: @VM.ActiveMineral?.Breitengrad | Lon: @VM.ActiveMineral?.Laengengrad
                        </span>
                    </div>
                    <button type="button" class="btn btn-secondary" data-testid="coordinate-picker-cancel-button" @onclick="VM.CloseCoordPicker">Abbrechen</button>
                    <button type="button" class="btn btn-primary px-4" data-testid="coordinate-picker-apply-button" @onclick="VM.CloseCoordPicker">Übernehmen</button>
                </div>
            </div>
        </div>
    </div>
}

@*Bildvorschau Modal*@
@if (VM.ShowImagePreview && !string.IsNullOrEmpty(VM.SelectedImageUrl))
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.8); z-index: 2000;" data-testid="image-preview-modal" @onclick="VM.CloseImagePreview">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-body p-0 text-center">
                    <img src="images/@VM.SelectedImageUrl" class="img-fluid rounded shadow-lg" style="max-height: 80vh;" />
                    <div class="mt-3 text-white">
                        <button class="btn btn-outline-light" data-testid="image-preview-close-button" @onclick="VM.CloseImagePreview">Schließen</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* Styles unverändert lassen *@
<style>
                .mineral-card {
                    transition: all 0.2s ease;
                    border-left: 4px solid transparent !important;
                }

                .mineral-card:hover {
                    transform: translateX(5px);
                    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
                    border-left-color: #0d6efd !important;
                }

                .text-truncate-2 {
                    display: -webkit-box;
                    -webkit-line-clamp: 2;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                }

                .bg-soft-success {
                    background-color: #f0fff4;
                }

                .sticky-top {
                    z-index: 10;
                }

                .custom-div-icon {
                    background: transparent !important;
                    border: none !important;
                }

                .marker-pin {
                    width: 40px !important;
                    height: 40px !important;
                    border-radius: 50%;
                    border: 3px solid white;
                    background-size: cover;
                    background-position: center;
                    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.4);
                    transition: transform 0.2s ease;
                    display: block !important;
                }

                .active-pin {
                    border-color: #0d6efd !important;
                    transform: scale(1.25);
                    box-shadow: 0 0 15px rgba(13, 110, 253, 0.8);
                    z-index: 1000 !important;
                }

                .clean-popup .leaflet-popup-content-wrapper {
                    padding: 0 !important;
                    overflow: hidden !important;
                    border-radius: 12px !important;
                    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2) !important;
                }

                .clean-popup .leaflet-popup-content {
                    margin: 0 !important;
                    width: 200px !important;
                }

                .popup-img {
                    width: 100% !important;
                    height: 130px !important;
                    object-fit: cover !important;
                    display: block !important;
                }

                .popup-text {
                    padding: 12px !important;
                    background: white;
                }

                .clean-popup .leaflet-popup-tip {
                    background: white;
                }

                .bg-light-blue {
                    background-color: #f0f7ff !important;
                }

                .table input {
                    background: transparent;
                }

                .table input:focus {
                    background-color: white !important;
                    box-shadow: inset 0 0 0 2px #0d6efd !important;
                    outline: none;
                }

                .text-nowrap {
                    white-space: nowrap;
                }

                .table-row-new {
                    background-color: rgba(253, 149, 13, 0.1) !important;
                    border-left: 5px solid #fd810d !important;
                }

                .table-row-new td {
                    background-color: transparent !important;
                    border-bottom: 1px solid rgba(13, 110, 253, 0.2);
                }

                .table-row-new input {
                    background-color: transparent !important;
                    color: #084298 !important;
                    /* Dunkelblaues Design */
                    font-weight: bold;
                }
            </style>

@code {
    [CascadingParameter] public string ActiveTab { get; set; } = "explorer";

    protected override async Task OnInitializedAsync()
    {
        // View-Updates abonnieren
        VM.OnChange += StateHasChanged;
        await VM.LoadMineralsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Synchronisiere den CascadingParameter in das VM, damit die Map-Filterung greift
        await VM.HandleTabChangedAsync(ActiveTab);
    }

    public void Dispose()
    {
        // Speicherleck verhindern!
        VM.OnChange -= StateHasChanged;
    }
}
