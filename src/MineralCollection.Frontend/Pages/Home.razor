@page "/"
@using MineralCollection.Domain
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="container-fluid h-100 p-0 overflow-hidden">
    <div class="row g-0 h-100" style="height: 100vh;">

        @* Linke Seite: Die Karte *@
        <div class="col-lg-8 col-md-7 position-relative bg-light border-end h-100">
            <div id="map" style="height: 100%; width: 100%;">
                <div class="d-flex h-100 align-items-center justify-content-center">
                    <p class="text-muted">Karte wird geladen...</p>
                </div>
            </div>
        </div>

        @* Rechte Seite: Galerie & Suche *@
        <div class="col-lg-4 col-md-5 d-flex flex-column bg-white h-100 shadow-sm" style="height: 100vh;">

            @* Such- und Filterbereich (Fixiert oben) *@
            <div class="p-3 border-bottom bg-light">
                <div class="input-group mb-2 shadow-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Mineral suchen..."
                           @bind="SearchTerm" @bind:event="oninput" />
                </div>

                <div class="d-flex align-items-center justify-content-between">
                    <small class="text-secondary fw-bold">@FilteredMinerals.Count() Funde</small>
                    <select class="form-select form-select-sm w-auto" @bind="sortBy">
                        <option value="Name">Sortieren: Name</option>
                        <option value="Region">Sortieren: Region</option>
                        <option value="Nummer">Sortieren: Nr.</option>
                    </select>
                </div>
            </div>

            @* Die Mineralienliste *@
            <div class="overflow-auto flex-grow-1 p-3 bg-white" style="overflow-y: auto !important;">
                @if (minerals == null)
                {
                    <div class="text-center p-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Lade Sammlung...</p>
                    </div>
                }
                else
                {
                    @foreach (var m in FilteredMinerals)
                    {
                        <div class="card mb-3 mineral-card border-0 shadow-sm" @onclick="() => HandleSelect(m.Id)"
                             style="cursor: pointer;">
                            <div class="row g-0">
                                <div class="col-4">
                                    @if (m.Images != null && m.Images.Any())
                                    {
                                        <img src="images/@m.Images.First().FileName" class="img-fluid rounded-start h-100"
                                             style="object-fit: cover; min-height: 110px;" alt="@m.Name">
                                    }
                                    else
                                    {
                                        <div class="bg-light h-100 d-flex align-items-center justify-content-center rounded-start">
                                            <i class="bi bi-camera text-muted fs-4"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-8">
                                    <div class="card-body p-2">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <h6 class="card-title fw-bold text-dark mb-0">@m.Name</h6>
                                            <span class="badge bg-light text-dark border"
                                                  style="font-size: 0.6rem;">#@m.Nummer</span>
                                        </div>

                                        <div class="text-muted small mb-1" style="font-size: 0.8rem;">
                                            <i class="bi bi-geo-alt-fill text-danger"></i> @m.Region, @m.Land
                                        </div>

                                        @if (!string.IsNullOrEmpty(m.Begleitmineral))
                                        {
                                            <div class="mb-1">
                                                <span class="badge bg-soft-success text-success border border-success"
                                                      style="font-size: 0.7rem;">
                                                    + @m.Begleitmineral
                                                </span>
                                            </div>
                                        }

                                        @if (!string.IsNullOrEmpty(m.Bemerkungen))
                                        {
                                            <p class="card-text text-muted small text-truncate-2 mb-0"
                                                   style="font-size: 0.7rem; line-height: 1.2;">
                                                @m.Bemerkungen
                                            </p>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<style>
    .mineral-card {
        transition: all 0.2s ease;
        border-left: 4px solid transparent !important;
    }

    .mineral-card:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
        border-left-color: #0d6efd !important;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .bg-soft-success {
        background-color: #f0fff4;
    }

    .clean-popup .leaflet-popup-content-wrapper {
        padding: 0;
        overflow: hidden;
        border-radius: 8px;
    }

    .clean-popup .leaflet-popup-content {
        margin: 0;
        width: 180px !important;
    }

    .popup-img {
        width: 100%;
        height: 120px;
        object-fit: cover;
        display: block;
    }

    .popup-text {
        padding: 10px;
    }

    .popup-title {
        margin: 0;
        font-weight: bold;
        font-size: 0.95rem;
    }

    .popup-sub {
        margin: 0;
        font-size: 0.8rem;
        color: #666;
    }

    .marker-pin {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 3px solid white;
        background-size: cover;
        background-position: center;
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

    .active-pin {
        border-color: #0d6efd !important;
        transform: scale(1.25);
        box-shadow: 0 0 15px rgba(13, 110, 253, 0.8);
        z-index: 1000 !important;
    }
</style>

@code {
    private List<Mineral>? minerals;
    private string _searchTerm = "";
    private string sortBy = "Name";

    // Automatisches Kartenupdate beim Tippen im Suchfeld
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                _ = UpdateMapAsync();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        minerals = await Http.GetFromJsonAsync<List<Mineral>>("api/minerals");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Karte initialisieren
            await JSRuntime.InvokeVoidAsync("mapBox.initialize", 51.1657, 10.4515, 5);

            // 2. Kleine Verzögerung, damit die Karte Zeit hat, sich zu initialisieren
            await Task.Delay(300);

            // 3. Marker nur setzen, wenn Daten da sind
            if (minerals != null && minerals.Any())
            {
                await JSRuntime.InvokeVoidAsync("mapBox.addMarkers", minerals);
            }
        }
    }

    private IEnumerable<Mineral> FilteredMinerals => minerals?
        .Where(m => string.IsNullOrWhiteSpace(_searchTerm) ||
               m.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
               (m.Fundort != null && m.Fundort.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)))
        .OrderBy(m => sortBy == "Name" ? m.Name : (sortBy == "Region" ? m.Region : m.Nummer))
        ?? Enumerable.Empty<Mineral>();

    private async Task UpdateMapAsync()
    {
        await JSRuntime.InvokeVoidAsync("mapBox.addMarkers", FilteredMinerals.ToList());
    }

    private async Task HandleSelect(int id)
    {
        await JSRuntime.InvokeVoidAsync("mapBox.focusMineral", id);
    }
}