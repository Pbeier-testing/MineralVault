@inherits LayoutComponentBase

<div class="page">
    @* Sidebar links *@
    <div class="sidebar-icons d-flex flex-column align-items-center py-3 bg-dark text-white shadow">
        <div class="mb-4"><i class="bi bi-gem fs-3 text-info"></i></div>
        
        @* Kartenmodus Button *@
        <button class="btn @(activeTab == "explorer" ? "btn-primary" : "btn-dark") mb-3 shadow-none"
                data-testid="nav-map-view"
                @onclick='() => SetTab("explorer")'>
            <i class="bi bi-map fs-4"></i>
        </button>
        
        @* Tabelle Button *@
        <button class="btn @(activeTab == "admin" ? "btn-primary" : "btn-dark") mb-3 shadow-none"
                data-testid="nav-table-view"
                @onclick='() => SetTab("admin")'>
            <i class="bi bi-table fs-4"></i>
        </button>
        
        <button class="btn btn-dark mb-3" data-testid="nav-add"><i class="bi bi-plus-circle fs-4"></i></button>
        
        <div class="mt-auto">
            <button class="btn btn-dark" data-testid="nav-settings"><i class="bi bi-gear fs-4"></i></button>
        </div>
    </div>

    @* Hauptbereich *@
    <main class="flex-grow-1 d-flex flex-column overflow-hidden">
        @* Wir geben den activeTab Status an die Home.razor weiter *@
        <CascadingValue Value="activeTab">
            @Body
        </CascadingValue>
    </main>
</div>

<style>
    .page {
        display: flex;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
    }

    .sidebar-icons {
        width: 70px;
        height: 100vh;
        z-index: 1000;
        flex-shrink: 0;
    }

    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
    
    /* Hover Effekt für Buttons */
    .sidebar-icons .btn:hover {
        background-color: #343a40;
        color: #0d6efd;
    }
</style>

@code {
    private string activeTab = "explorer";

    private void SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged(); // Zwingt das Layout und den Inhalt zum Neuzeichnen
    }
}
